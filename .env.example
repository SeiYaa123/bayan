# Database
DATABASE_URL=postgresql://akashic:akashic@localhost:5432/akashic_db
REDIS_URL=redis://localhost:6379

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# API
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Embedding model (local ou hosted)
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024

# Rate limiting (free tier)
FREE_TIER_DAILY_LIMIT=20

# Admin (protège /api/admin/stats)
ADMIN_SECRET_KEY=change-me-in-production

# SEO / URLs
NEXT_PUBLIC_BASE_URL=https://akashicsearch.com

# CORS (virgule-séparées)
ALLOWED_ORIGINS=http://localhost:3000,https://akashicsearch.com
